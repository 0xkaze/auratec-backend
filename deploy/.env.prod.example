# ── Auratec produção (VPS) ──────────────────────────────────────
# Copie pra `.env` na pasta ~/auratec da VPS e preencha. NÃO versionar.

# Domínio público (aponte o DNS A/AAAA pra IP da VPS ANTES do 1º deploy,
# senão o Caddy não consegue emitir o certificado).
PUBLIC_DOMAIN=app.seudominio.com
# URL completa https (deve ser https://$PUBLIC_DOMAIN). Usada em CORS e
# em links de email. DEVE ser igual ao NEXT_PUBLIC_API_URL do build do front.
PUBLIC_URL=https://app.seudominio.com

# Postgres (interno ao compose; não exposto na internet).
POSTGRES_USER=auratec
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=auratec

# Auth — gere com: openssl rand -base64 64
JWT_SECRET=troque-por-no-minimo-32-caracteres-aleatorios
JWT_ACCESS_TTL=7d

# Emails que viram admin automaticamente (vírgula-separados). Opcional.
ADMIN_EMAILS=
