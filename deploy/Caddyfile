# Caddy — proxy reverso + HTTPS automático (Let's Encrypt).
# Um domínio só: API/estáticos do backend sob caminhos fixos, resto
# vai pro Next. PUBLIC_DOMAIN vem do ambiente (compose).

{$PUBLIC_DOMAIN} {
	encode zstd gzip

	# Backend: API, GLBs estáticos e health-check.
	@backend path /api/* /objetos/* /health
	handle @backend {
		reverse_proxy backend:3001
	}

	# Tudo o mais → frontend (Next.js).
	handle {
		reverse_proxy frontend:3000
	}
}
# ── Z6 Market: cole este bloco no Caddyfile do auratec (o Caddy que já roda na VPS) ──
#
# Pré-requisitos:
#   1) docker network create gmstech-web
#   2) conectar o Caddy do auratec a essa rede (uma vez):
#        docker network connect gmstech-web <container-do-caddy>
#      (ou adicionar `gmstech-web` (external) às networks do serviço caddy no compose dele)
#   3) DNS (todos → IP da VPS, para o Caddy emitir o HTTPS de cada um):
#        z6market.com.br        A    <IP>     (apex — domínio CANÔNICO)
#        www.z6market.com.br    A    <IP>     (registro.br não aceita CNAME no apex; use A)
#        z6market.com           A    <IP>
#        www.z6market.com       A    <IP>
#
# O Caddy resolve `z6-backend`/`z6-frontend` pelo nome (rede compartilhada) e
# provisiona o HTTPS de cada domínio automaticamente. WebSocket passa transparente.

# ── Domínio CANÔNICO (serve o app) ──────────────────────────────────────────
z6market.com.br {
	encode zstd gzip
	request_body {
		max_size 12MB
	}

	# WebSocket de tempo real → backend.
	@ws path /ws
	handle @ws {
		reverse_proxy z6-backend:3333
	}

	# API REST → backend.
	handle /api/* {
		reverse_proxy z6-backend:3333
	}

	# Tudo o mais → frontend Next.js.
	handle {
		reverse_proxy z6-frontend:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# ── Aliases → 301 para o canônico ───────────────────────────────────────────
# Mantém sessão/OAuth/SEO num lugar só. O app só funciona no apex z6market.com.br;
# www, o domínio .com e o subdomínio antigo redirecionam pra cá.
www.z6market.com.br, z6market.com, www.z6market.com, z6market.gmstech.dev {
	redir https://z6market.com.br{uri} permanent
}
