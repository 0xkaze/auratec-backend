# Database
# Porta 5433 (não 5432) pra evitar conflito com Postgres local.
# A docker-compose.yml mapeia 5433 do host pro 5432 do container.
DATABASE_URL=postgres://auratec:auratec@localhost:5433/auratec

# Server
PORT=3001
# Origens permitidas no CORS (vírgula-separadas). Em prod, listar
# explicitamente. Em dev, http://localhost:3000 cobre o Next.
CORS_ORIGINS=http://localhost:3000

# Auth
# Gere com: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Tempo de vida do access token (formato jose, ex: '7d', '1h', '15m')
JWT_ACCESS_TTL=7d

# Emails que ganham role 'admin' automaticamente ao registrar/logar.
# Vírgula-separados. Case-insensitive. Em branco = sem admins automáticos
# (só o admin do seed inicial). Exemplo:
# ADMIN_EMAILS=guilherme@auratec.local,founder@auratec.local
ADMIN_EMAILS=

# Ambiente: development | production | test
NODE_ENV=development
